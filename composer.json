{
  "name": "pdro-lucas/filament-ai-writer",
  "description": "AI Writer Action for Filament Forms — supports OpenAI, Claude and Gemini",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "filament",
    "ai",
    "laravel",
    "openai",
    "claude",
    "gemini"
  ],
  "authors": [
    {
      "name": "Pedro Lucas",
      "homepage": "https://github.com/pdro-lucas"
    }
  ],
  "require": {
    "php": "^8.1",
    "filament/filament": "^4.0 || ^5.0",
    "illuminate/support": "*",
    "illuminate/http": "*"
  },
  "require-dev": {
    "laravel/framework": "^10.0 || ^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": {
      "PdroLucas\\FilamentAiWriter\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PdroLucas\\FilamentAiWriter\\FilamentAiWriterServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
